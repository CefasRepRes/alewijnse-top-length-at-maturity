model {

  # priors
  theta0 ~ dnorm(0, 0.001)
  theta1 ~ dnorm(0, 0.001)
  theta2 ~ dnorm(0, 0.001)
  delta ~ dunif(1, 20)
  gamma ~ dnorm(0, 0.001)T(0,)
  tau ~ dgamma(0.01, 0.01)

  # likelihood
  for (i in 1:n) {
    lp[i] = theta0 + theta1 * (x[i] - delta) + theta2 * sqrt((x[i] - delta)^2 + gamma)
    y[i] ~ dnorm(lp[i], tau)
  }

}
